__pycache__/
*.pyc
.pytest_cache/
.mypy_cache/
.ruff_cache/
.ipynb_checkpoints/
.DS_Store
.env
.venv/
*.egg-info/
.snakemake/

# Data: keep structure but not raw files
data/raw/*
data/interim/*
data/processed/*
!data/raw/.gitkeep
!data/interim/.gitkeep
!data/processed/.gitkeep

# Bioinfo large files
*.fastq
*.fastq.gz
*.fq
*.fq.gz
*.bam
*.bai
*.sam
*.cram
*.crai
*.vcf
*.vcf.gz
*.h5ad
*.loom
*.rds
*.RData

# MLflow / logs / artifacts
mlruns/
results/mlflow/
results/logs/*.log

# Literature raw API dumps (regenerable; metadata only, no large files)
literature/raw/*
!literature/raw/.gitkeep

# Regenerable analysis outputs
results/figures/*
results/tables/*
results/metrics/*
manuscript/figures/*
!results/figures/.gitkeep
!results/tables/.gitkeep
!results/metrics/.gitkeep
!manuscript/figures/.gitkeep

# Quarto / LaTeX artifacts
/.quarto/
manuscript/_site/
*.aux
*.bbl
*.blg
*.log
*.out
*.toc
